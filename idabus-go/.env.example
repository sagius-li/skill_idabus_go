# authorization_code triggers browser-based login with PKCE
# client_credentials is for service-to-service calls, and requires client secret
OAUTH_FLOW_TYPE=authorization_code
OAUTH_TOKEN_URL=https://identity.example.com/oauth/token
OAUTH_AUTHORIZATION_URL=https://identity.example.com/oauth/authorize
OAUTH_CLIENT_ID=idabus-client
OAUTH_SCOPE=idabus.read
OAUTH_REDIRECT_HOST=127.0.0.1
OAUTH_REDIRECT_PORT=8765

IDABUS_API_BASE_URL=https://your-app.azurewebsites.net/api
IDABUS_RESOURCE_PATH_TEMPLATE=/resources/{resource_id}
IDABUS_API_TIMEOUT=30

# Client credentials example:
# OAUTH_FLOW_TYPE=client_credentials
# OAUTH_CLIENT_ID=idabus-service
# OAUTH_CLIENT_SECRET=replace-me
# OAUTH_SCOPE=idabus.read
